  const L=txt.split("\n");let h="",iT=false,tR=[];
  function fT(){
    if(tR.length<2){tR=[];return"";}
    const hds=tR[0].split("|").filter(c=>c.trim()).map(c=>c.trim());
    const drs=tR.slice(2).map(r=>r.split("|").filter(c=>c.trim()).map(c=>c.trim()));
    tR=[];
    let o='<div class="md-tbl"><table><thead><tr>';
    hds.forEach((hd,i)=>{o+='<th style="text-align:'+(i===0?'left':'center')+'">'+ri(hd)+'</th>';});
    o+='</tr></thead><tbody>';
    drs.forEach(row=>{o+='<tr>';row.forEach((c,i)=>{o+='<td style="text-align:'+(i===0?'left':'center')+'">'+ri(c)+'</td>';});o+='</tr>';});
    return o+'</tbody></table></div>';
  }
  for(let i=0;i<L.length;i++){
    const l=L[i];
    if(l.startsWith("|")){iT=true;tR.push(l);continue;}
    else if(iT){iT=false;h+=fT();}
    if(!l.trim())continue;
    if(l.startsWith("> "))h+='<div class="md-bq">'+ri(l.slice(2))+'</div>';
    else if(l.startsWith("- "))h+='<div class="md-li">'+ri(l.slice(2))+'</div>';
    else if(/^\d+\./.test(l))h+='<div class="md-li">'+ri(l)+'</div>';
    else if(l.startsWith("**Q.")||l.startsWith("**Q "))h+='<div class="md-q">'+ri(l)+'</div>';
    else if(l.startsWith("→"))h+='<div class="md-a">'+ri(l)+'</div>';
    else h+='<p class="md-p">'+ri(l)+'</p>';
  }
  if(iT)h+=fT();
  return h;
}

function R(){
  if(S.pg==="home")renderHome();
  else if(S.pg==="defs")renderDefs();
  else{renderStudy();attachSwipe();}
}

function renderHome(){
  const tP=Object.keys(S.pr).length;
  const tS=D.reduce((s,dd)=>s+T.filter(t=>dd.sections[t.id]||(t.id==="quiz"&&dd.qa.length>0)).length,0);
  const tV=Object.values(S.vc).reduce((a,b)=>a+b,0);

  let cards='';
  cards+='<div class="def-btn" onclick="goDefs()"><div class="def-btn-icon">📚</div><div class="def-btn-info"><div class="def-btn-title">용어 정의 모음</div><div class="def-btn-sub">'+DEFS.length+'개 핵심 용어 · 검색 가능</div></div><div style="color:#3b82f6;font-size:18px">→</div></div>';

  D.forEach((d,i)=>{
    const vc=S.vc["d"+d.day]||0;
    const av=T.filter(t=>d.sections[t.id]||(t.id==="quiz"&&d.qa.length>0));
    const done=av.filter(t=>S.pr["d"+d.day+"-"+t.id]);
    cards+='<div class="ch-card" onclick="goStudy('+i+')"><div class="ch-num" style="background:'+GC[d.grade]+'">'+String(d.day).padStart(2,"0")+'</div><div class="ch-info"><div class="ch-title">'+d.title+'</div><div class="ch-meta"><span class="ch-badge" style="background:'+GC[d.grade]+'">'+d.grade+'</span><span class="ch-score">빈출 '+d.score+'</span></div></div><div class="ch-right"><div class="ch-views">'+vc+'</div><div class="ch-views-lbl">조회</div><div class="ch-prog">'+av.map(t=>'<div class="ch-dot" style="background:'+(S.pr["d"+d.day+"-"+t.id]?"#22c55e":"#334155")+'"></div>').join("")+'</div></div></div>';
  });

  document.getElementById("app").innerHTML='<div class="home-hdr"><div class="home-title">🛣️ 도로기술사 데일리학습</div><div class="home-sub">구술면접 30일 완성 · 도로분야</div><div class="home-stats"><div class="home-stat"><div class="home-stat-num">'+tP+'</div><div class="home-stat-lbl">완료 / '+tS+'</div></div><div class="home-stat"><div class="home-stat-num">'+tV+'</div><div class="home-stat-lbl">총 조회</div></div><div class="home-stat"><div class="home-stat-num">'+Math.round(tP/tS*100)+'%</div><div class="home-stat-lbl">달성률</div></div></div></div><div class="home-scroll">'+cards+'</div>';
}

function renderDefs(){
  const q=S.dsrc.toLowerCase();
  const filtered=q?DEFS.filter(d=>d.term.toLowerCase().includes(q)||d.def.toLowerCase().includes(q)):DEFS;
  let cards=filtered.map(d=>'<div class="def-card"><span class="def-day">'+(d.day>0?'Day '+String(d.day).padStart(2,'0'):'📜 규칙 제2조')+'</span><div class="def-term">'+d.term+'</div><div class="def-text">'+d.def+'</div></div>').join("");
  if(!filtered.length)cards='<p style="color:#64748b;text-align:center;padding:40px">검색 결과가 없습니다</p>';

  document.getElementById("app").innerHTML='<div class="hdr"><div class="hdr-r"><button class="back-btn" onclick="goHome()">←</button><div class="tarea"><div class="ttl">📚 용어 정의 모음</div><div style="color:#94a3b8;font-size:12px;margin-top:2px">'+DEFS.length+'개 핵심 용어 (학습카드 '+DEFS.filter(d=>d.day>0).length+'개 + 규칙 제2조 '+DEFS.filter(d=>d.day===0).length+'개)</div></div></div></div><div class="ct" id="ct"><input class="search-box" type="text" placeholder="용어 검색..." value="'+S.dsrc+'" oninput="searchDef(this.value)">'+cards+'</div>';
}

function renderStudy(){
  const d=D[S.d];
  const cc=T.filter(t=>S.pr["d"+d.day+"-"+t.id]).length;
  const av=T.filter(t=>d.sections[t.id]||(t.id==="quiz"&&d.qa.length>0));
  const mm=String(Math.floor(S.tm/60)).padStart(2,"0");
  const ss=String(S.tm%60).padStart(2,"0");
  const vc=S.vc["d"+d.day]||0;

  let tb=T.map(t=>{
    const ok=d.sections[t.id]||(t.id==="quiz"&&d.qa.length>0);
    const dn=S.pr["d"+d.day+"-"+t.id];
    return'<div class="tab '+(S.t===t.id?"on":"")+(ok?"":" off")+'" onclick="'+(ok?"cT(\'"+t.id+"\')":"void(0)")+'">'+t.ic+" "+t.l+(dn?'<span class="ck">✓</span>':'')+'</div>';
  }).join("");

  let ct="";
  if(S.t==="quiz"){
    ct='<div class="qhdr">Q&A '+d.qa.length+'문 + 함정 '+d.traps.length+'문 · 탭하여 정답 확인</div>';
    d.qa.forEach((qa,i)=>{
      const rv=S.rv.has(i);
      ct+='<div class="qc nm" id="qc-'+i+'" onclick="tQ('+i+')"><div class="qt"><span class="qb" style="background:#3b82f6">Q'+(i+1)+'</span><span class="qq">'+qa.q+'</span></div><div class="qa-slot">'+(rv?'<div class="qa" style="color:#86efac">'+qa.a+'</div>':'<div class="qh">탭하여 정답 확인</div>')+'</div></div>';
    });
    if(d.traps.length>0){
      ct+='<div class="tl">🚨 함정 문제</div>';
      d.traps.forEach((t,i)=>{
        const rv=S.rv.has("t"+i);
        ct+='<div class="qc tp" id="qc-t'+i+'" onclick="tQ(\'t'+i+'\')"><div class="qt"><span class="qb" style="background:#ef4444">🚨</span><span class="qq">'+t.q+'</span></div><div class="qa-slot">'+(rv?'<div class="qa" style="color:#fca5a5">'+t.a+'</div>':'<div class="qh">탭하여 정답 확인</div>')+'</div></div>';
      });
    }
  }else{
    ct=rmd(d.sections[S.t]||null);
  }

  document.getElementById("app").innerHTML='<div class="hdr"><div class="hdr-r"><button class="back-btn" onclick="goHome()">←</button><div class="tarea"><div class="ttl">Day '+String(d.day).padStart(2,"0")+' · '+d.title+'</div><div class="mt"><span class="bdg" style="background:'+GC[d.grade]+'">'+d.grade+'</span><span class="mts">빈출 '+d.score+'</span><span class="mts">'+cc+'/'+av.length+'</span><span class="mts">조회 '+vc+'</span></div></div><div class="tmr"><span id="tmr-v" class="tmr-d" style="color:'+(S.tm<60?'#ef4444':'#e2e8f0')+'">'+mm+':'+ss+'</span><button id="tmr-b" class="tmr-b" style="background:'+(S.tr?'#ef4444':'#22c55e')+'" onclick="tTm()">'+(S.tr?'■':'▶')+'</button></div></div></div><div class="tabs">'+tb+'</div><div class="ct" id="ct">'+ct+'</div><div class="bt"><button class="nb" onclick="pD()"'+(S.d===0?' disabled':'')+'>◀ 이전</button><button class="cb" style="background:'+(S.pr["d"+d.day+"-"+S.t]?'#065f46':'#3b82f6')+'" onclick="mD()">'+(S.pr["d"+d.day+"-"+S.t]?'✓ 완료':'완료 체크')+'</button><button class="nb" onclick="nD()"'+(S.d===29?' disabled':'')+'>다음 ▶</button></div>';
}

function goHome(){S.pg="home";clearInterval(ti);S.tr=false;R();}
function goStudy(i){
  S.pg="study";S.d=i;S.t="basic";S.rv=new Set();
  S.vc["d"+D[i].day]=(S.vc["d"+D[i].day]||0)+1;
  sv();R();
}
function goDefs(){S.pg="defs";S.dsrc="";R();}
function searchDef(v){S.dsrc=v;renderDefs();}
function cT(id){S.t=id;S.rv=new Set();R();setTimeout(()=>{const e=document.getElementById("ct");if(e)e.scrollTop=0;attachSwipe();},0);}
function availTabs(){
  const d=D[S.d];
  return T.filter(t=>d.sections[t.id]||(t.id==="quiz"&&d.qa.length>0));
}
function swipeTab(dir){
  const av=availTabs();
  const idx=av.findIndex(t=>t.id===S.t);
  if(idx===-1)return;
  const newIdx=idx+dir;
  if(newIdx<0||newIdx>=av.length)return;
  cT(av[newIdx].id);
}
let touchStartX=0,touchStartY=0,touchActive=false;
function attachSwipe(){
  const ct=document.getElementById("ct");
  if(!ct||ct._swipeAttached)return;
  ct._swipeAttached=true;
  ct.addEventListener("touchstart",e=>{
    if(e.touches.length!==1)return;
    touchStartX=e.touches[0].clientX;
    touchStartY=e.touches[0].clientY;
    touchActive=true;
  },{passive:true});
  ct.addEventListener("touchend",e=>{
    if(!touchActive)return;
    touchActive=false;
    const dx=e.changedTouches[0].clientX-touchStartX;
    const dy=e.changedTouches[0].clientY-touchStartY;
    if(Math.abs(dx)>60&&Math.abs(dx)>Math.abs(dy)*1.5){
      if(dx<0)swipeTab(1);
      else swipeTab(-1);
    }
  },{passive:true});
}
function tQ(idx){
  const isRevealed=S.rv.has(idx);
  if(isRevealed)S.rv.delete(idx);else S.rv.add(idx);

  const card=document.getElementById("qc-"+idx);
  if(!card){R();return;}
  const slot=card.querySelector(".qa-slot");
  if(!slot){R();return;}

  const d=D[S.d];
  let item;
  if(String(idx).startsWith("t")){
    item=d.traps[parseInt(String(idx).slice(1))];
    slot.innerHTML=(!isRevealed)?'<div class="qa" style="color:#fca5a5">'+item.a+'</div>':'<div class="qh">탭하여 정답 확인</div>';
  }else{
    item=d.qa[idx];
    slot.innerHTML=(!isRevealed)?'<div class="qa" style="color:#86efac">'+item.a+'</div>':'<div class="qh">탭하여 정답 확인</div>';
  }
}
function mD(){
  const ct=document.getElementById("ct");const st=ct?ct.scrollTop:0;
  const d=D[S.d];S.pr["d"+d.day+"-"+S.t]=true;sv();R();
  setTimeout(()=>{const ct2=document.getElementById("ct");if(ct2)ct2.scrollTop=st;},0);
}
function pD(){if(S.d>0)goStudy(S.d-1);}
function nD(){if(S.d<29)goStudy(S.d+1);}
function uTm(){
  const mm=String(Math.floor(S.tm/60)).padStart(2,"0");
  const ss=String(S.tm%60).padStart(2,"0");
  const el=document.getElementById("tmr-v");
  if(el){el.textContent=mm+":"+ss;el.style.color=S.tm<60?"#ef4444":"#e2e8f0";}
}
function tTm(){
  S.tr=!S.tr;
  if(S.tr){ti=setInterval(()=>{if(S.tm>0){S.tm--;uTm();}else{clearInterval(ti);S.tr=false;uTm();}},1000);}
  else{clearInterval(ti);}
  uTm();
  const btn=document.getElementById("tmr-b");
  if(btn){btn.textContent=S.tr?"■":"▶";btn.style.background=S.tr?"#ef4444":"#22c55e";}
}

R();
</script>
